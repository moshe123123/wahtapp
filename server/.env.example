# מפתח סודי שהתוסף בכרום ישתמש בו כדי לאמת בקשות מול השרת
API_KEY=change-me-to-a-long-random-string

# כתובת המייל שאליה יישלחו הודעות נכנסות (הכתובת שמסוננת ע"י נטפרי)
DESTINATION_EMAIL=you@gmail.com

# פרטי חשבון SMTP לשליחת מיילים (למשל Gmail App Password, לא הסיסמה הרגילה)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password

# פורט שהשרת יאזין עליו (Render מגדיר PORT אוטומטית, אפשר להשאיר ריק)
PORT=3000
