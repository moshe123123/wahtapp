# --- פרטים שמתקבלים מ-Meta for Developers (developers.facebook.com) ---
# לאחר יצירת אפליקציה מסוג Business + הוספת מוצר WhatsApp

# Access Token של System User (קבוע, לא זמני) - נוצר תחת Business Settings > System Users
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxx

# מזהה מספר הטלפון (Phone Number ID) - מוצג בדשבורד של מוצר ה-WhatsApp באפליקציה
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# מזהה חשבון ה-WhatsApp Business (WABA ID)
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345

# מזהה האפליקציה וסוד האפליקציה (App ID / App Secret) - מוצגים בדף ההגדרות הבסיסיות של האפליקציה
META_APP_ID=xxxxxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# מחרוזת סודית שאתה בוחר בעצמך - תצטרך להזין אותה גם בהגדרות ה-Webhook במטא
WEBHOOK_VERIFY_TOKEN=choose-any-secret-string

# מפתח שהאתר/התוסף ישתמשו בו כדי לאמת בקשות מול השרת שלך (לא קשור למטא)
API_KEY=change-me-to-a-long-random-string

# כתובת המייל שאליה יועברו הודעות נכנסות
DESTINATION_EMAIL=you@gmail.com

# פרטי SMTP לשליחת מיילים
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password

PORT=3000
