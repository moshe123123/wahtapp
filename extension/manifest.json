{
  "manifest_version": 3,
  "name": "WhatsApp for Gmail Bridge",
  "version": "1.0.0",
  "description": "ממשק וואטסאפ מדומה בתוך Gmail, מחובר לשרת גשר אישי",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
